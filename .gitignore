# =============================================================================
# Fe El Seka — .gitignore
# Stack: Next.js 14 + Python FastAPI + Python AI Service + Supabase + OSRM
# =============================================================================


# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.test
*.pem
*.key
*.cert
*.p12
*.pfx
service-account.json
google-credentials.json
firebase-adminsdk*.json


# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# =============================================================================
# IDEs & Editors
# =============================================================================

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.#*


# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.npm/
package-lock.json
