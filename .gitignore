# =============================================================================
# Next.js
# =============================================================================
.next/
out/
build/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts


# =============================================================================
# TypeScript
# =============================================================================
dist/
*.js.map
*.d.ts.map
# Keep *.d.ts from packages — do not add *.d.ts globally


# =============================================================================
# Python
# =============================================================================

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.virtualenv/
__pypackages__/

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
sdist/
.installed.cfg
lib/
lib64/
MANIFEST
# Next.js lib source is not a Python virtualenv lib — un-ignore it
!apps/main/src/lib/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
pytest.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# IPython / Jupyter
.ipython/
.jupyter/
*.ipynb_checkpoints/
profile_default/
ipython_config.py


