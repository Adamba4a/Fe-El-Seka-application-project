DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Twilio SMS (for phone OTP via Supabase Auth)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGE_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

API_VERSION=0.1.0

# Phase 4 — Ride Management
# Leave RESEND_API_KEY empty/placeholder → emails go to Mailpit (local dev)
# Set a real key for production → emails go via Resend
RESEND_API_KEY=re_your_resend_api_key_here
WEBHOOK_SECRET=generate_with__python_-c_"import secrets; print(secrets.token_hex(32))"

# SMTP (Mailpit) — only used when RESEND_API_KEY is not configured
SMTP_HOST=127.0.0.1
SMTP_PORT=54325

# Docker — when running via docker compose, change SUPABASE_URL above to:
#   SUPABASE_URL=http://host.docker.internal:54321
BACKEND_INTERNAL_URL=http://api:8000
LOG_LEVEL=info
