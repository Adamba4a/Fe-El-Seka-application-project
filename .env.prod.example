# =============================================================================
# Triplyy — Production environment (docker-compose.prod.yml)
# Copy to .env.prod at the repo root (git-ignored) and fill in real values.
# This single file is shared via `env_file: .env.prod` across the api, ai,
# and main services — each container only reads the vars it needs.
# =============================================================================

# --- Hosted Supabase project (Project Settings → API / Database) ---
# Use the connection pooler (port 6543), not the direct 5432 URL, so the
# container's asyncpg pool goes through pgbouncer instead of exhausting
# hosted Postgres connection limits.
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:6543/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# --- api service ---
API_VERSION=0.1.0
# Comma-separated list of allowed frontend origins (real production domain(s))
CORS_ORIGINS=https://your-production-domain.com
WEBHOOK_SECRET=generate_with__python_-c_"import secrets; print(secrets.token_hex(32))"
INTERNAL_SECRET=generate_with__python_-c_"import secrets; print(secrets.token_hex(32))"
AI_SERVICE_URL=http://ai:8000
# No `osrm` service exists in docker-compose.prod.yml — point this at wherever
# OSRM is actually hosted in production before going live.
OSRM_URL=http://osrm:5000

# Real transactional/notification email (ride cancellations, etc.) — leave
# empty or a re_your_-prefixed placeholder to fall back to local SMTP; set a
# real key so notification_service.py sends via Resend instead.
RESEND_API_KEY=re_your_resend_api_key_here

# --- ai service ---
AI_VERSION=0.1.0
MODEL_REGISTRY_BUCKET=model-registry

# --- main (Next.js) service ---
# NOTE: NEXT_PUBLIC_* values here only affect this file's documentation —
# Next.js bakes NEXT_PUBLIC_* vars into the client bundle at `next build`
# time. Setting them here does nothing unless the Docker build step (CI)
# is updated to pass them as build args. See go-live plan for details.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_API_URL=https://your-production-domain.com
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org
BACKEND_INTERNAL_URL=http://api:8000
LOG_LEVEL=info
